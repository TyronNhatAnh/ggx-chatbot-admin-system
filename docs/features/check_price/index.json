{
  "feature": "check_price",
  "use_cases": [
    {
      "id": "UC-1",
      "title": "Guest/User Price Estimation",
      "actor": "Guest or Authenticated User",
      "trigger": "User requests a delivery quote for standard or home-moving services",
      "preconditions": [
        "Order type is identified (Standard vs Home Moving)"
      ],
      "happy_path": [
        "Frontend identifies OrderType",
        "If Home Moving, client calls /guest/home-moving/estimate",
        "If Standard, client calls /guest/estimate",
        "Backend calculates price based on parameters",
        "ResultOrder is returned to client"
      ],
      "edge_cases": [
        "Invalid OrderType provided in params",
        "Missing address/waypoint data"
      ],
      "business_value": "Provides transparency on costs before order commitment",
      "api_paths": [
        "POST /guest/estimate",
        "POST /guest/home-moving/estimate",
        "POST /estimate"
      ],
      "evidence_refs": [
        {
          "file": "src/lib/apis/order.ts",
          "symbol": "OrderAPIs.estimate"
        },
        {
          "file": "internal/api/http/v1/routes.go",
          "symbol": "orderHandler.EstimateGuest"
        }
      ]
    },
    {
      "id": "UC-2",
      "title": "Coupon Management and Application",
      "actor": "Authenticated User",
      "trigger": "User wants to view or register a discount coupon",
      "preconditions": [
        "User is logged in"
      ],
      "happy_path": [
        "User requests available coupons via GET /coupons",
        "User registers a new coupon code via POST /coupons/register-user",
        "System validates coupon and associates it with user"
      ],
      "edge_cases": [
        "Invalid coupon code",
        "Coupon already registered"
      ],
      "business_value": "Increases conversion through marketing incentives",
      "api_paths": [
        "GET /coupons",
        "POST /coupons/register-user"
      ],
      "evidence_refs": [
        {
          "file": "internal/api/http/v1/routes.go",
          "symbol": "couponNewHandler.GetCouponsByUserId"
        }
      ]
    },
    {
      "id": "UC-3",
      "title": "E-Tax Invoice Issuance",
      "actor": "Guest User",
      "trigger": "User requires a tax invoice for a completed order",
      "preconditions": [
        "Order ID exists",
        "Business registration number is valid"
      ],
      "happy_path": [
        "User verifies business registration number",
        "User retrieves order data for E-Tax",
        "User submits tax invoice issuance request",
        "System processes invoice"
      ],
      "edge_cases": [
        "Invalid business registration number",
        "Order not eligible for tax invoice"
      ],
      "business_value": "Compliance with local tax regulations for business users",
      "api_paths": [
        "GET /guest/etax/get-order/:id",
        "GET /guest/etax/verify_biz_registration_number/:biz_registration_number",
        "POST /guest/etax/issue_tax_invoice"
      ],
      "evidence_refs": [
        {
          "file": "src/lib/apis/order.ts",
          "symbol": "OrderAPIs.createIssueTaxInvoice"
        }
      ]
    }
  ],
